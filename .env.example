# Copia este archivo como .env y rellena los valores reales
# cp .env.example .env

# Laravel
APP_KEY=base64:GENERA_CON_php_artisan_key_generate

# Supabase PostgreSQL
# Settings > Database > Connection parameters
DB_HOST=db.[TU_PROJECT_REF].supabase.co
DB_USERNAME=postgres.[TU_PROJECT_REF]
DB_PASSWORD=TU_PASSWORD_SUPABASE

# Google OAuth
# https://console.cloud.google.com → Credenciales → ID de cliente OAuth
GOOGLE_CLIENT_ID=TU_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=TU_GOOGLE_CLIENT_SECRET
